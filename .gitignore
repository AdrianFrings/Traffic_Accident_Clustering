# Local environment files
.vscode/
*.envs/
*.env

# Ignoring the build files for latex
report/*.aux
report/*.log
report/*.out
report/*.gz

*__pycache__/

# Ignore files in src/data that are not pdf files
src/data/[0-9]*.csv

# Ignore everything in src/media that isn't in a subdirectory of src/media/videos
src/media/*
!src/media/videos/
src/media/videos/**/partial_movie_files/

# Ignore MAC files
*.DS_Store

# Ignore large raw CSV data to prevent gigantic repository sizes
data/*.csv
!data/city_info.csv
Urban_Mobility_Risk_App/data/*.csv
!Urban_Mobility_Risk_App/data/city_info.csv
# Also ignore Mac OS artifacts
.DS_Store
